<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background:#f4f7fb;font-family:Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f7fb;padding:30px 0;">
    <tr>
        <td align="center">

            <table width="700" cellpadding="0" cellspacing="0"
                   style="background:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 8px 25px rgba(0,0,0,0.08);">

                <tr>
                    <td style="background:linear-gradient(135deg,#0f172a,#1e3a8a);padding:40px;color:white;">

                        <h1 style="margin:0;font-size:32px;">
                            📚 Library Management System
                        </h1>

                        <p style="margin-top:20px;font-size:18px;color:#e2e8f0;">
                            Hello,
                        </p>

                        <h2 style="font-size:36px;margin:10px 0;">
                            Your OTP Code for Verification
                        </h2>

                        <p style="font-size:16px;line-height:28px;color:#cbd5e1;">
                            Use the following One-Time Password (OTP)
                            to verify your account and continue.
                        </p>

                    </td>
                </tr>

                <tr>
                    <td align="center" style="padding:50px 30px;">

                        <h2 style="color:#1e3a8a;">
                            Your OTP Code
                        </h2>

                        <div style="
                            display:inline-block;
                            padding:18px 45px;
                            font-size:42px;
                            font-weight:bold;
                            letter-spacing:12px;
                            color:#1e3a8a;
                            background:#eef4ff;
                            border:2px dashed #3b82f6;
                            border-radius:15px;">
                            ${otp}
                        </div>

                        <div style="
                            margin-top:25px;
                            padding:15px;
                            background:#f8fafc;
                            border-radius:12px;
                            display:inline-block;
                            color:#334155;
                            font-size:16px;">
                            ⏱️ This OTP is valid for <b style="color:#2563eb;">3 minutes</b> only.
                        </div>

                    </td>
                </tr>

                <tr>
                    <td style="padding:0 40px 30px 40px;">

                        <div style="
                            background:#f0fdf4;
                            border:1px solid #bbf7d0;
                            border-radius:15px;
                            padding:20px;">

                            <h3 style="color:#15803d;margin-top:0;">
                                🔒 For Your Security
                            </h3>

                            <p style="margin:0;color:#374151;line-height:26px;">
                                Do not share this OTP with anyone.
                                Our library team will never ask for your OTP.
                            </p>

                        </div>

                    </td>
                </tr>

                <tr>
                    <td style="padding:0 40px 30px 40px;">

                        <h3 style="color:#1e293b;">
                            📖 Need Help?
                        </h3>

                        <p style="color:#64748b;line-height:26px;">
                            If you didn't request this OTP,
                            simply ignore this email.
                            For assistance, contact your library administrator.
                        </p>

                    </td>
                </tr>

                <tr>
                    <td align="center"
                        style="background:#0f172a;color:white;padding:25px;">

                        <h3 style="margin:0;">
                            📚 Library Management System
                        </h3>

                        <p style="margin-top:10px;color:#cbd5e1;">
                            Secure • Fast • Reliable
                        </p>

                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>
</body>
</html>





